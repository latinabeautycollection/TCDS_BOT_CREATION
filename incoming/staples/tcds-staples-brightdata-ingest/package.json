{
  "name": "@tcds/staples-brightdata-ingest",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "DATABASE_URL=postgresql://test:test@localhost/test BRIGHT_DATA_API_TOKEN=1234567890_test node --import tsx --test test/*.test.ts",
    "start": "node dist/src/index.js",
    "dev": "tsx src/index.ts",
    "migrate": "tsx src/migrate.ts",
    "dlq:replay": "tsx src/replay-dlq.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
