  "description": "Green Tier 1 enterprise Bright Data Micro Center ingestion into the retail schema.",
  "type": "module",
  "engines": { "node": ">=20.11.0" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
