    "trigger": "tsx src/cli.ts trigger",
    "resume": "tsx src/cli.ts resume",
    "ingest:file": "tsx src/cli.ts ingest-file",
    "health": "tsx src/cli.ts health",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "pg": "^8.13.3",
    "pino": "^9.6.0",
