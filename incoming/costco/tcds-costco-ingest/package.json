{
  "name": "@tcds/costco-brightdata-ingest",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "migrate": "psql \"$DATABASE_URL\" -v ON_ERROR_STOP=1 -f sql/001_costco_ingest.sql",
    "dlq:replay": "tsx src/replay-dlq.ts"
  },
  "engines": { "node": ">=20.11" },
  "dependencies": {
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
