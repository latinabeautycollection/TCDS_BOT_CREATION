{
  "name": "tcds-pqp-testbed",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx apps/pqp-api/src/server.ts",
    "build": "tsc",
    "start": "node dist/apps/pqp-api/src/server.js",
    "smoke": "tsx scripts/pqp-smoke-test.ts",
    "phase2:smoke": "tsx scripts/pqp-phase2-smoke-test.ts",
    "phase3:baseline": "tsx scripts/pqp-longitudinal-baseline.ts",
    "ci:gate": "tsx scripts/pqp-ci-gate.ts",
    "lab:profiles": "tsx scripts/register-lab-profiles.ts",
    "lab:run": "tsx scripts/owned-lab-runner.ts",
    "coverage:smoke": "tsx scripts/pqp-coverage-smoke-test.ts",
    "real:capability:smoke": "tsx scripts/real-capability-smoke-test.ts",
    "pqp:phase4:4-1:smoke": "tsx scripts/pqp-phase4-4-1-smoke-test.ts",
    "qa:report": "tsx scripts/generate-qa-report.ts",
    "pqp:owned-lab:check": "tsx -e \"const base=(process.env.PQP_BASE_URL || 'http://127.0.0.1:8088'); fetch(base + '/pqp/labs/owned-checkout-lab.html').then(r=>{if(!r.ok)process.exit(1);console.log('owned lab ok')})\"",
    "pqp:owned-lab:v4:smoke": "tsx scripts/pqp-owned-lab-v4-smoke-test.ts",
    "qa:host-emission": "tsx scripts/generate-host-emission-check.ts",
    "qa:proxy-stability": "tsx scripts/generate-proxy-stability-report.ts",
    "qa:mlx-fingerprint-audit": "tsx scripts/import-mlx-fingerprint-audit.ts",
    "qa:profile-location-alignment": "tsx scripts/generate-profile-location-alignment.ts",
    "qa:anthony-phase1-brief": "tsx scripts/generate-anthony-phase1-db-brief.ts",
    "qa:ip-geo-sources": "tsx scripts/geo/generate-ip-geo-source-checks.ts",
    "qa:browser-geolocation": "tsx scripts/geo/generate-browser-geolocation-checks.ts",
    "qa:navigator-screen": "tsx scripts/fingerprint/generate-navigator-screen-checks.ts",
    "mlx:rebrowser:owned-lab": "tsx scripts/mlx/rebrowser-owned-lab-check.ts",
    "mlx:puppeteer-stealth:owned-lab": "tsx scripts/mlx/puppeteer-stealth-owned-lab-check.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^8.1.0",
    "@fingerprintjs/fingerprintjs": "^4.6.2",
    "axios": "^1.18.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "http-proxy-agent": "^9.1.0",
    "pg": "^8.13.1",
    "playwright": "^1.52.0",
    "puppeteer-core": "^25.1.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-anonymize-ua": "^2.4.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "rebrowser-playwright": "^1.52.0",
    "user-agents": "^2.1.99",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "type": "module"
}
